# ============================================================
# Environment Variables — Backend Pustaka Digital Al-Qur'an
# ============================================================
# Salin file ini menjadi .env dan isi nilainya:
#   cp .env.example .env
# ============================================================

# ── Google Gemini API Key ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Qdrant Vector Database ──────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=quran_hybrid_collection

# ── Embedding Model ─────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=cpu

# ── LLM Configuration ───────────────────────────────────────
LLM_PRIMARY_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3

# ── RAG Tuning ──────────────────────────────────────────────
# Skor cosine similarity minimum (0.0 - 1.0).
# Dokumen di bawah threshold ini = negative rejection.
SIMILARITY_THRESHOLD=0.45

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT=10/minute

# ── Firebase Authentication ─────────────────────────────────
# Path ke file service account JSON dari Firebase Console.
# Kosongkan untuk menggunakan Application Default Credentials.
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Set false untuk development tanpa Firebase Auth.
AUTH_ENABLED=true

# ── CORS Origins ────────────────────────────────────────────
# Comma-separated list. Gunakan * untuk development.
CORS_ORIGINS=["*"]
